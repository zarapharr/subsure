# --- Core ---
NODE_ENV=development

# --- Database ---
# Neon (dev/preview/prod) or local docker postgres.
DATABASE_URL=postgres://user:password@localhost:5432/subsure

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_CREDENTIALS_DEMO_EMAIL=demo@subsure.dev
AUTH_CREDENTIALS_DEMO_PASSWORD=changeme123

# --- Plaid (configured in SUB Plaid ticket) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Optional: only needed if you configure Plaid webhooks.
# PLAID_WEBHOOK_URL=https://example.com/api/plaid/webhook
# Optional: protect /api/cron/plaid-refresh when using Vercel Cron.
PLAID_REFRESH_CRON_SECRET=

# --- Analytics (wired in follow-up) ---
POSTHOG_KEY=

# --- Error monitoring (wired in follow-up) ---
SENTRY_DSN=
