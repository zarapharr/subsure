{
  "name": "subsure",
  "version": "0.0.1",
  "private": true,
  "description": "SubSure — validate every recurring charge you pay for.",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:subscriptions": "tsx scripts/evaluate-subscription-fixtures.ts",
    "verify:launch": "tsx scripts/launch-verification-check.ts",
    "verify:launch:mock": "tsx scripts/launch-verification-check.ts --mock-mode",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.7.2",
    "drizzle-orm": "0.33.0",
    "next": "14.2.15",
    "next-auth": "5.0.0-beta.20",
    "plaid": "^19.0.0",
    "postgres": "3.4.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.3.0",
    "@typescript-eslint/parser": "8.3.0",
    "autoprefixer": "10.4.20",
    "dotenv": "16.4.5",
    "drizzle-kit": "0.24.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15",
    "eslint-config-prettier": "9.1.0",
    "postcss": "8.4.41",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.6",
    "tailwindcss": "3.4.10",
    "tsx": "4.19.0",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
